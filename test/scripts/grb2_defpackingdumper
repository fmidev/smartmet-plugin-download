#!/bin/bash

if [ $# -eq 0 ] || [ ! -s "$1" ]; then
  echo "$0: args: file expected"
  exit 1
fi

grb="$1"
shift

if [ $# -eq 0 ]; then
  set -- -for_n 1 -vt -ijlat 5 5
fi

start=1
end=1
step=1
declare -a POINT_INDEX POINT_COORDS

while [ $# -gt 0 ]; do
  case "$1" in
    -for_n)
      spec="$2"
      shift 2
      IFS=':' read -r a b c <<< "$spec"
      start="$a"; end="$b"; step="$c";
      ;;
    -ijlat)
      i="$2"
      j="$3"
      let idx=$i*$j
      shift 3
      # Convert to linear index (1-based)
      # But we do NOT use Ni and Nj — we treat them as sequential point numbers
      POINT_INDEX+=("$idx")
      POINT_COORDS+=("$i,$j")
      ;;
    *)
      shift
      ;;
  esac
done

for ((msg=start; msg<=end; msg+=step)); do

  vt=$(grib_get -w count=$msg -p validityDate,validityTime "$grb" \
       | awk '{printf "%s%02d",$1,$2}')

  printf "vt=%s:" "$vt"

  grib_get_data -w count=$msg "$grb" | tail -n +2 | \
  awk -v points="${POINT_INDEX[*]}" -v coords="${POINT_COORDS[*]}" '
    BEGIN {
      split(points, p)
      for (k in p) want[p[k]] = 1
      split(coords, c)
      n=1
    }
    NR in want {
      printf "(%s),lon=%.6f,lat=%.6f,val=%.2f:",
             c[n], $2, $1, $3
      n++
    }
  '

  printf "\n"
done
